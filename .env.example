# LLM Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# IMPORTANT: Use 'export' prefix so env vars reach Docker containers

# === Option A: Local GPU inference (vLLM, ollama, etc.) ===
export LLM_BASE_URL=http://host.docker.internal:8000/v1
export LLM_API_KEY=not-needed
export LLM_MODEL=deepseek-ai/DeepSeek-V3

# === Option B: OpenRouter API ===
# export LLM_BASE_URL=https://openrouter.ai/api/v1
# export LLM_API_KEY=sk-or-v1-your-key-here
# export LLM_MODEL=openrouter/minimax/minimax-m2.5

# Note: Arena submissions always use MiniMax M2.5 (forced by competition).
# For local iteration, use any capable model. Skills improvements should
# transfer across models. DeepSeek V3, Qwen 2.5, or Llama 3.1 70B+ recommended.
