# Arena Competition API Keys
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# IMPORTANT: Use 'export' prefix so env vars reach Docker containers

# OpenRouter (LLM inference for local testing)
export OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Arena CLI authentication token
export ARENA_TOKEN=your-arena-auth-token
